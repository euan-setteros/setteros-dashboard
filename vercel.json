{
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/trpc/[trpc].ts": {
      "includeFiles": "server/**,drizzle/**,shared/**"
    }
  },
  "rewrites": [
    { "source": "/api/trpc/:path*", "destination": "/api/trpc/[trpc]" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
